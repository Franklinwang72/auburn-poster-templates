% ======================================================================
%  Auburn University Research Poster -- accessible (PDF/UA-1 tagged)
%  THEME: Astronomy -- a night at the observatory, drawn as a page from
%  a celestial atlas. Moonlit cool-white paper, deep-space indigo ink,
%  star-gold accents; a star-studded night ribbon along the top, a faint
%  orbit system in one corner, constellation charts (the Big Dipper,
%  Cassiopeia) along the bottom margin, and an EB Garamond serif title
%  in the manner of a classical star atlas. The one dark panel -- the
%  theorem card -- is a gold-rimmed piece of night sky.
%
%  One clear mathematical idea: 120 x 72 cm landscape, three columns
%  with a centre-stage hierarchy -- the main theorem sits in the ONLY
%  dark panel above one strong visual (the Calabi-Yau quintic surface).
%
%  Because this poster is a plain article (not beamer), it compiles to
%  a REAL tagged, PDF/UA-1 conformant PDF: reading order, language, and
%  the logo, figures, and QR code tagged as Figures with alt text.
%
%  COMPILE WITH LuaLaTeX:
%    * Overleaf:  Menu -> Compiler -> LuaLaTeX, then Recompile.
%    * Locally:   latexmk
% ======================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{postertheme}[2026/07/04 poster-research-astronomy poster theme]


% Fail fast, with a clear message, if the wrong engine is used.
\RequirePackage{iftex}
\RequireLuaTeX

% ----- page: 120 x 72 cm landscape --------------------------------------
\RequirePackage[paperwidth=120cm, paperheight=72cm,
            top=2.4cm, bottom=2.0cm, left=3.4cm, right=3.4cm]{geometry}
\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.55em}
\setlength{\emergencystretch}{1.5em}  % kill loose justified lines

% ----- sans body (Source Sans 3) + atlas serif titles + STIX math -------
\RequirePackage{fontspec}
\setmainfont{SourceSans3}[Path=fonts/, Extension=.otf,
  UprightFont=*-Regular, BoldFont=*-Bold,
  ItalicFont=*-It,       BoldItalicFont=*-BoldIt]
\newfontfamily\PosterSemibold{SourceSans3}[Path=fonts/, Extension=.otf,
  UprightFont=*-Semibold, Ligatures=TeX]
\newfontfamily\PosterMedium{SourceSans3}[Path=fonts/, Extension=.otf,
  UprightFont=*-Medium, Ligatures=TeX]
\newfontfamily\DisplaySerif{EBGaramond}[Path=fonts/, Extension=.otf,
  UprightFont=*-SemiBold, ItalicFont=*-Italic, Ligatures=TeX]
\RequirePackage{mathtools}
\RequirePackage{booktabs}
\RequirePackage{graphicx}
\RequirePackage{tikz}
\usetikzlibrary{calc}
\RequirePackage{unicode-math}
\setmathfont{STIXTwoMath-Regular.otf}[Path=fonts/]
\setoperatorfont\symup

% ----- colour: moonlit paper, deep-space indigo, star gold ---------------
\RequirePackage{xcolor}
\definecolor{NightPaper}{RGB}{245,247,252}   % moonlit cool-white ground
\definecolor{NightSky}{RGB}{15,26,52}        % deep-space indigo (ribbons)
\definecolor{StarGold}{RGB}{233,196,106}     % bright star gold (on dark)
\definecolor{GoldDeep}{RGB}{172,124,40}      % deep gold (marks on paper)
\definecolor{MoonPale}{RGB}{225,232,245}     % faint moonlight stars
\definecolor{NebulaViolet}{RGB}{112,92,160}  % soft nebula violet
\definecolor{AUnavy}{RGB}{17,30,58}          % main text; card ground
\definecolor{AUorange}{RGB}{198,108,32}      % warm amber accent
\definecolor{AUgray}{RGB}{95,103,118}        % cool slate secondary
\pagecolor{NightPaper}
\color{AUnavy}

% ----- tagged figures (hero, trio, torus, logo, QR), thesis pattern -----
\RequirePackage{qrcode}
\RequirePackage{zref-savepos}
\ExplSyntaxOn
\box_new:N \l__pfig_box
\int_new:N \g__pfig_int
\tl_new:N  \l__pfig_alt_tl
\cs_generate_variant:Nn \tag_struct_begin:n { e }
% \PosterFigure{<alt text>}{<content>} -- tag <content> as ONE Figure
% with alt text and a bounding box, exactly like an included image.
\NewDocumentCommand{\PosterFigure}{mm}{%
  \leavevmode
  \tl_set:Ne \l__pfig_alt_tl {#1}%
  \tag_struct_begin:e { tag=Figure , alt={\tl_to_str:N \l__pfig_alt_tl} }%
  \tag_mc_begin:n {}%
  \tag_suspend:n {pfig}%
  \hbox_set:Nn \l__pfig_box {#2}%
  \tag_resume:n {pfig}%
  \int_gincr:N \g__pfig_int
  \zsavepos { pfig \int_use:N \g__pfig_int }%
  \tag_struct_gput:ene { \tag_get:n {struct_num} } { attribute }
    { /O~/Layout~/BBox~[
        \dim_to_decimal_in_bp:n { \zposx{pfig\int_use:N\g__pfig_int} sp } ~
        \dim_to_decimal_in_bp:n { \zposy{pfig\int_use:N\g__pfig_int} sp
                                  - \box_dp:N \l__pfig_box } ~
        \dim_to_decimal_in_bp:n { \zposx{pfig\int_use:N\g__pfig_int} sp
                                  + \box_wd:N \l__pfig_box } ~
        \dim_to_decimal_in_bp:n { \zposy{pfig\int_use:N\g__pfig_int} sp
                                  + \box_ht:N \l__pfig_box } ] }%
  \box_use_drop:N \l__pfig_box
  \tag_mc_end:
  \tag_struct_end:
}
\ExplSyntaxOff

% ----- links -------------------------------------------------------------
