% ----- poster vocabulary -------------------------------------------------
% A four-pointed star ("sparkle") drawn inline; #1 = colour, #2 = scale.
\newcommand{\StarFour}[2]{%
  \tikz[baseline=-0.60ex,scale=#2]{\fill[#1]
    (0,0.30) .. controls (0.055,0.055) .. (0.30,0)
    .. controls (0.055,-0.055) .. (0,-0.30)
    .. controls (-0.055,-0.055) .. (-0.30,0)
    .. controls (-0.055,0.055) .. cycle;}}
% Quiet section label (navy, tracked caps) led by a gold star; [AUorange]
% marks the ONE main-result label.
\NewDocumentCommand{\PosterSection}{O{AUnavy} m}{%
  \par\vspace{0.78em}%
  {\raggedright\PosterSemibold\fontsize{22.6}{27.0}\selectfont\color{#1}%
   \StarFour{GoldDeep}{0.92}%
   \hspace{0.30em}\addfontfeatures{LetterSpace=5}\MakeUppercase{#2}\par}%
  \vspace{0.10em}%
  {\color{NebulaViolet!52}\rule{0.82\linewidth}{1.35pt}\par}%
  \vspace{-0.04em}}
% Run-in term label.
\newcommand{\auterm}[1]{{\PosterSemibold #1}}
\newcommand{\auhead}[1]{{\PosterSemibold #1}}
\newcommand{\PosterBody}{\fontsize{24.1}{33.0}\selectfont}
