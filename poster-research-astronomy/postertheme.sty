    \draw[AUnavy!55,line width=1.3pt]
      (0.28,0.18) -- (0.78,0.44) -- (1.26,0.16) -- (1.74,0.40) -- (2.22,0.10);
    \foreach \x/\y in {0.28/0.18,0.78/0.44,1.26/0.16,1.74/0.40,2.22/0.10}{
      \fill[AUnavy!80] (\x,\y) circle (0.055);}
