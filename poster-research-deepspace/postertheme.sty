% Full-page backdrop, painted back to front: nebula glows, a dim
% all-over starfield, an astrolabe dial behind the title, a gold
% hairline frame, then the observatory horizon (teal glow, rising moon,
% ground, dome with a lit slit, pines), bright star lanes down the two
% column gutters and margins, sparkles, and one shooting star.
\newcommand{\StyleBackdrop}{%
  \begin{tikzpicture}[remember picture,overlay]
    % --- nebula glows (radial fades into the page ink) ---
    \shade[inner color=NebulaViolet!24!SpaceInk,outer color=SpaceInk]
      ($(current page.north west)+(60cm,-6.6cm)$) ellipse (27cm and 7.6cm);
    \shade[inner color=NebulaTeal!20!SpaceInk,outer color=SpaceInk]
      ($(current page.north west)+(15cm,-4.4cm)$) ellipse (12cm and 5.2cm);
    \shade[inner color=NebulaViolet!18!SpaceInk,outer color=SpaceInk]
      ($(current page.north west)+(114cm,-30cm)$) circle (9cm);
    \shade[inner color=NebulaViolet!15!SpaceInk,outer color=SpaceInk]
      ($(current page.north west)+(60cm,-52cm)$) ellipse (13cm and 8.5cm);
    \shade[inner color=NebulaTeal!16!SpaceInk,outer color=SpaceInk]
      ($(current page.north west)+(6cm,-62cm)$) ellipse (14cm and 6.5cm);
    % --- dim all-over starfield (quasi-random, deterministic) ---
    \foreach \i in {1,...,110}{
      \pgfmathsetmacro\sx{mod(\i*37.31,112.0)+4.0}
      \pgfmathsetmacro\sy{mod(\i*23.917,60.0)+3.6}
      \pgfmathsetmacro\sr{0.024+0.012*mod(\i,3)}
      \pgfmathsetmacro\so{0.10+0.033*mod(\i,3)}
      \fill[MoonWhite,opacity=\so]
        ($(current page.north west)+(\sx cm,-\sy cm)$) circle (\sr cm);}
    % --- astrolabe dial behind the title ---
    \draw[MoonWhite,opacity=0.09,line width=1.5pt]
      ($(current page.north west)+(60cm,-7.2cm)$) ++(196:12.6cm)
      arc[start angle=196,end angle=-16,radius=12.6cm];
    \foreach \a in {180,166,...,0}{
      \draw[MoonWhite,opacity=0.11,line width=1.1pt]
        ($(current page.north west)+(60cm,-7.2cm)+(\a:12.6cm)$) --
        ($(current page.north west)+(60cm,-7.2cm)+(\a:12.25cm)$);}
    % --- gold hairline frame (the horizon will rise over it) ---
    \draw[StarGold!55,line width=1.2pt]
      ([xshift=1.25cm,yshift=-1.25cm]current page.north west)
      rectangle
      ([xshift=-1.25cm,yshift=1.25cm]current page.south east);
    % --- observatory horizon along the bottom ---
    \shade[top color=SpaceInk,bottom color=NebulaTeal!22!SpaceInk]
      ($(current page.south west)+(0,2.4cm)$) rectangle (current page.south east);
    \fill[StarGold!85,opacity=0.95]                       % rising moon
      ($(current page.south west)+(111.3cm,0.55cm)$) circle (1.05cm);
    \fill[SpaceDeep]                                      % rolling ground
      ($(current page.south west)+(0,0.98cm)$)
      .. controls +(14cm,0.30cm) and +(-16cm,-0.10cm) ..
      ($(current page.south west)+(38cm,1.10cm)$)
      .. controls +(12cm,-0.22cm) and +(-14cm,0.16cm) ..
      ($(current page.south west)+(72cm,0.80cm)$)
      .. controls +(15cm,0.30cm) and +(-12cm,-0.06cm) ..
      ($(current page.south west)+(104cm,1.04cm)$)
      .. controls +(8cm,0.10cm) and +(-6cm,0.02cm) ..
      ($(current page.south west)+(120cm,0.94cm)$)
      -- (current page.south east) -- (current page.south west) -- cycle;
    \fill[SpaceDeep]                                      % observatory dome
      ($(current page.south west)+(10.7cm,0.6cm)$)
      rectangle ($(current page.south west)+(13.5cm,1.42cm)$);
    \fill[SpaceDeep]
      ($(current page.south west)+(13.5cm,1.40cm)$)
      arc[start angle=0,end angle=180,radius=1.4cm] -- cycle;
    \draw[StarGold,line width=2.2pt,line cap=round]       % the lit slit
      ($(current page.south west)+(12.42cm,1.62cm)$) --
      ($(current page.south west)+(12.66cm,2.66cm)$);
    \fill[StarGold,opacity=0.85]                          % a lit window
      ($(current page.south west)+(11.18cm,0.98cm)$)
      rectangle ($(current page.south west)+(11.48cm,1.24cm)$);
    \foreach \x/\h/\w in {7.6/1.7/0.55, 8.6/2.3/0.75, 9.5/1.5/0.5,
                          106.4/2.0/0.65, 107.5/2.7/0.85, 108.9/1.8/0.6,
                          116.2/2.2/0.7, 117.3/1.6/0.55}{ % pine silhouettes
      \fill[SpaceDeep]
        ($(current page.south west)+(\x cm-\w cm,0.9cm)$) --
        ($(current page.south west)+(\x cm,\h cm+0.9cm)$) --
        ($(current page.south west)+(\x cm+\w cm,0.9cm)$) -- cycle;}
    % --- bright star lanes down the two column gutters ---
    \foreach \gx in {38.5, 81.5}{
      \foreach \dy/\dx/\r/\o in {18.2/0.2/0.062/0.85, 22.6/-0.5/0.045/0.55,
        27.1/0.55/0.078/0.95, 31.8/-0.25/0.042/0.5, 36.4/0.35/0.060/0.8,
        41.2/-0.6/0.048/0.6, 45.9/0.15/0.075/0.9, 50.6/-0.4/0.045/0.55,
        55.2/0.5/0.062/0.8, 59.8/-0.15/0.048/0.6}{
        \fill[MoonWhite,opacity=\o]
          ($(current page.north west)+(\gx cm+\dx cm,-\dy cm)$) circle (\r cm);}
      \fill[StarGold,opacity=0.9]
        ($(current page.north west)+(\gx cm-0.3cm,-24.8cm)$) circle (0.055cm);
      \fill[StarGold,opacity=0.9]
        ($(current page.north west)+(\gx cm+0.4cm,-48.3cm)$) circle (0.055cm);}
    \fill[MoonWhite,opacity=0.9,shift={($(current page.north west)+(38.3cm,-33.9cm)$)},scale=0.55]
      (0,0.30) .. controls (0.055,0.055) .. (0.30,0)
      .. controls (0.055,-0.055) .. (0,-0.30)
      .. controls (-0.055,-0.055) .. (-0.30,0)
      .. controls (-0.055,0.055) .. cycle;
    \fill[StarGold,shift={($(current page.north west)+(81.7cm,-57.4cm)$)},scale=0.60]
      (0,0.30) .. controls (0.055,0.055) .. (0.30,0)
      .. controls (0.055,-0.055) .. (0,-0.30)
      .. controls (-0.055,-0.055) .. (-0.30,0)
      .. controls (-0.055,0.055) .. cycle;
    % a crescent adrift in the second star lane
    \fill[StarGold,opacity=0.95] ($(current page.north west)+(81.5cm,-27.6cm)$) circle (0.34cm);
    \fill[SpaceInk] ($(current page.north west)+(81.67cm,-27.48cm)$) circle (0.295cm);
    % --- bright stars: side margins, top corners, footer dust ---
    \foreach \y/\r/\o in {9.5/0.055/0.7, 16.0/0.042/0.5, 23.5/0.068/0.85,
      31.0/0.042/0.5, 38.5/0.058/0.7, 46.0/0.068/0.85, 53.5/0.042/0.5,
      60.5/0.058/0.7}{
      \fill[MoonWhite,opacity=\o]
        ($(current page.north west)+(2.30cm,-\y cm)$) circle (\r cm);
      \fill[MoonWhite,opacity=\o]
        ($(current page.north east)+(-2.30cm,-\y cm)$) circle (\r cm);}
    \fill[StarGold,opacity=0.9] ($(current page.north west)+(2.30cm,-42.2cm)$) circle (0.050cm);
    \fill[StarGold,opacity=0.9] ($(current page.north east)+(-2.30cm,-19.8cm)$) circle (0.050cm);
    \foreach \x/\y/\r/\o in {5.2/3.4/0.06/0.8, 8.9/5.6/0.045/0.55,
      13.4/3.0/0.07/0.9, 18.2/5.2/0.045/0.6, 22.5/3.6/0.055/0.75,
      97.0/3.2/0.06/0.8, 100.8/5.4/0.045/0.55, 104.9/3.0/0.065/0.85}{
      \fill[MoonWhite,opacity=\o]
        ($(current page.north west)+(\x cm,-\y cm)$) circle (\r cm);}
    \foreach \x/\y/\r/\o in {8/68.6/0.05/0.5, 22/69.2/0.04/0.4,
      35/68.4/0.055/0.55, 50/69.0/0.04/0.4, 66/68.5/0.05/0.5,
      80/69.1/0.04/0.4, 92/68.4/0.05/0.5}{
      \fill[MoonWhite,opacity=\o]
        ($(current page.north west)+(\x cm,-\y cm)$) circle (\r cm);}
    \fill[StarGold!90,shift={($(current page.north west)+(10.6cm,-4.4cm)$)},scale=0.66]
      (0,0.30) .. controls (0.055,0.055) .. (0.30,0)
      .. controls (0.055,-0.055) .. (0,-0.30)
      .. controls (-0.055,-0.055) .. (-0.30,0)
      .. controls (-0.055,0.055) .. cycle;
    \fill[StarGold!90,shift={($(current page.north west)+(101.9cm,-4.1cm)$)},scale=0.66]
      (0,0.30) .. controls (0.055,0.055) .. (0.30,0)
      .. controls (0.055,-0.055) .. (0,-0.30)
