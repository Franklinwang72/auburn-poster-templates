     \fill[StarGold] (0,0.02) circle (0.068);
     \fill[StarGold] (0.27,0.21) circle (0.050);
     \fill[StarGold] (0.54,0.07) circle (0.068);}%
   \hspace{0.30em}\addfontfeatures{LetterSpace=5}\MakeUppercase{#2}\par}%
