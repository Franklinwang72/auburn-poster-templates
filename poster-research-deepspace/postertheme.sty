\newif\ifposter@firstcol
\newenvironment{postercolumns}
  {\poster@firstcoltrue\noindent\ignorespaces}
  {\unskip\par}
% \begin{postercolumn}         -> a side column (0.295\textwidth)
% \begin{postercolumn}[wide]   -> the centre column (0.35\textwidth)
\newenvironment{postercolumn}[1][narrow]{%
  \ifposter@firstcol\global\poster@firstcolfalse\else\hfill\fi
  \def\poster@w{0.295}%
  \def\poster@tmp{#1}\def\poster@wide{wide}%
  \ifx\poster@tmp\poster@wide\def\poster@w{0.35}\fi
  \begin{minipage}[t][\BodyH][s]{\poster@w\textwidth}\PosterBody
}{\end{minipage}\ignorespaces}

% ---- sections: plain \section works, straight from your paper ----------
\RenewDocumentCommand{\section}{s o m}{\PosterSection{#3}}
\RenewDocumentCommand{\subsection}{s o m}{\par\vspace{0.35em}\auterm{#3.}\ \ignorespaces}
\RenewDocumentCommand{\paragraph}{s o m}{\par\auterm{#3.}\ \ignorespaces}
\NewDocumentCommand{\accentsection}{m}{\PosterSection[AUorange]{#1}}
\NewDocumentCommand{\term}{m}{\auterm{#1}}

% --- theorem: the poster's ONE highlighted panel -------------------------
% \begin{theorem}[attribution] ... \end{theorem}; inside it, \punchline{...}
% sets one display-size equation in the accent colour.
\newcommand{\punchline}[1]{{\fontsize{38}{45}\selectfont
  \begin{equation*}#1\end{equation*}}}
\NewEnviron{theorem}[1][]{%
  \par\vspace{0.3em}%
{\setlength{\fboxrule}{1.8pt}%
\fcolorbox{StarGold}{MoonCard}{\begin{minipage}{\dimexpr\textwidth-3em}
  \vspace{0.9em}\begin{center}\begin{minipage}{\dimexpr\textwidth-3em}
  {\PosterSemibold\fontsize{24}{30}\selectfont\color{CardAmber}%
   \StarFour{CardAmber}{1.0}\hspace{0.28em}%
   \addfontfeatures{LetterSpace=8}THEOREM\quad
   {\addfontfeatures{LetterSpace=5}(\MakeUppercase{#1})}\par}
  \vspace{0.5em}
  {\color{AUnavy}\fontsize{29}{41}\selectfont
  \BODY\par}
  \end{minipage}\end{center}\vspace{0.9em}
\end{minipage}}}\par}

% ---- quiet theorem-like environments (paste from your paper) -----------
% \begin{definition}[name] ... \end{definition}   and likewise lemma,
% proposition, corollary, remark, example, conjecture; plus proof.
\newcommand{\poster@runin}[2]{%
  \par\addvspace{0.40em}%
  {\PosterSemibold\color{MoonWhite}#1\IfNoValueTF{#2}{}{\ (#2)}.}\ \ignorespaces}
\DeclareDocumentEnvironment{definition}{o}{\poster@runin{Definition}{#1}}{\par}
\DeclareDocumentEnvironment{lemma}{o}{\poster@runin{Lemma}{#1}}{\par}
\DeclareDocumentEnvironment{proposition}{o}{\poster@runin{Proposition}{#1}}{\par}
\DeclareDocumentEnvironment{corollary}{o}{\poster@runin{Corollary}{#1}}{\par}
\DeclareDocumentEnvironment{remark}{o}{\poster@runin{Remark}{#1}}{\par}
\DeclareDocumentEnvironment{example}{o}{\poster@runin{Example}{#1}}{\par}
\DeclareDocumentEnvironment{conjecture}{o}{\poster@runin{Conjecture}{#1}}{\par}
\newcommand{\posterqedsymbol}{%
  \tikz[baseline=0.02cm]\draw[line width=1.1pt] (0,0) rectangle (0.26,0.26);}
\DeclareDocumentEnvironment{proof}{o}
  {\par\addvspace{0.30em}{\itshape\IfNoValueTF{#1}{Proof}{#1}.}\ \ignorespaces}
  {\hfill\posterqedsymbol\par}

% ---- the footer: references text inside, QR block automatic ------------
\NewEnviron{posterfooter}{%
\vspace{0.36cm}

\noindent\begin{minipage}{\textwidth}
{\color{AUgray!40}\rule{\textwidth}{1.2pt}}
\vspace{0.55em}

\begin{minipage}[c]{0.78\textwidth}
  \PosterSmall\color{AUgray}
\BODY
  \par
\end{minipage}\hfill
\begin{minipage}[c]{0.14\textwidth}
  \raggedleft
  \begin{minipage}{4.6cm}
    \centering
    % QR on a small bright card: dark modules on light scan reliably;
    % an inverted (light-on-dark) QR often does not. The group resets
    % hyperref's urlcolor, which the qrcode package prints with.
    \PosterFigure{QR code linking to the LinkedIn profile of \PosterAuthors\ at \PosterQRURL}%
                 {\setlength{\fboxsep}{8pt}\colorbox{MoonCard}{\begingroup
                    \hypersetup{urlcolor=AUnavy}%
                    \qrcode[height=3.15cm]{\PosterQRURL}\endgroup}}\par
    \vspace{5pt}
    {\PosterSemibold\fontsize{15}{20}\selectfont\color{AUorange} \PosterQRLabel{}\par}
  \end{minipage}
\end{minipage}
\end{minipage}}

\endinput
