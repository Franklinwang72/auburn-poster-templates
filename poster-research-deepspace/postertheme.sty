% motif + right logo) make the centre block -- and so the title -- sit
% exactly in the middle of the page. Tracked caps: planetarium-poster
% typography, moonlight on the night sky.
\begin{minipage}[c]{0.18\textwidth}
  \raggedright
  \StyleMotif
\end{minipage}\hfill
\begin{minipage}[c]{0.58\textwidth}\centering
  {\PosterSemibold\fontsize{78}{86}\selectfont
   % A \hspace* glue here crashes tagpdf's interword-space scan at this
   % display size (luaotfload-auxiliary "attempt to index a nil value
   % fontdata"), so no left compensation for LetterSpace's trailing pad
   % is applied. (The \kern below lands in vertical mode -- it adds a
   % harmless whisker of height above the title, not horizontal space.)
   \kern0.07em\addfontfeatures{LetterSpace=7}\MakeUppercase{\DisplayTitle}\par}
  \vspace{0.42em}
  {\fontsize{36}{46}\selectfont\color{AUgray}
   \StarFour{StarGold}{0.78}\hspace{0.55em}{\itshape \TechTitle}%
   \hspace{0.55em}\StarFour{StarGold}{0.78}\par}
