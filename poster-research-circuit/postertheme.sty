  {\DisplayMono\itshape\fontsize{31}{40}\selectfont\color{AUgray} \TechTitle\par}
  \vspace{0.55em}
  {\fontsize{27}{35}\selectfont \PosterAuthors\;
   {\color{AUgray}\textperiodcentered\; \PosterDept}\par}
\end{minipage}\hfill
\begin{minipage}[c]{0.18\textwidth}
  \raggedleft
  \includegraphics[height=6.2cm,
    alt={Full-color Auburn University AU logo}]{auburn-logo-color-cropped.png}
\end{minipage}

\vspace{0.55em}
{\centering\PosterSemibold\fontsize{37}{48}\selectfont\color{AUorange}\Contribution\par}
\vspace{0.34em}
