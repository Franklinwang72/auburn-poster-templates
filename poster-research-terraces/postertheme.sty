% ----- poster vocabulary -------------------------------------------------
% A single tilted leaf with a light mid-vein; #1 = colour.
\newcommand{\LeafMark}[1]{%
  \tikz[baseline=-0.55ex]{%
    \fill[#1,rotate around={-30:(0.15,0.02)}]
      (0.15,0.02) ellipse (0.21 and 0.088);
    \draw[CardWhite,line width=1.0pt,line cap=round]
      (0.02,-0.06) -- (0.28,0.10);}}
% Quiet mixed-case section head: leaf, deep-pine title, hairline.
% [AUorange] (terracotta) marks the ONE main-result label.
\NewDocumentCommand{\PosterSection}{O{Pine} m}{%
  \par\vspace{0.80em}%
  {\raggedright\PosterSemibold\fontsize{23.5}{28.2}\selectfont\color{#1}%
   \LeafMark{#1}\hspace{0.34em}#2\par}%
  \vspace{0.14em}%
  {\color{Sage!55}\rule{0.34\linewidth}{1.0pt}\par}%
  \vspace{-0.02em}}
% Run-in term label.
\newcommand{\auterm}[1]{{\PosterSemibold #1}}
\newcommand{\auhead}[1]{{\PosterSemibold #1}}
\newcommand{\PosterBody}{\fontsize{24.1}{33.0}\selectfont}
\newcommand{\PosterSmall}{\fontsize{19.2}{26.0}\selectfont}
\newcommand{\PosterCaption}{\fontsize{17.4}{23.2}\selectfont}
% Full-page backdrop, painted back to front: the terraced valley (each
% band a sweeping curve with a thin contour line on its ridge, tints
% deepening toward the bottom), a pale morning sun, three birds, then
% the white cards -- flat shadow, card, hairline border -- that the
% text columns and the footer sit on.
\newcommand{\StyleBackdrop}{%
  \begin{tikzpicture}[remember picture,overlay]
    % --- terrace bands (top edge y, curve amplitude, colour) ---
    \foreach \yy/\aa/\bb/\cc in {
        15.5/1.60/-1.20/Sage!14,
        23.6/-1.40/1.90/Wheat!18,
        31.6/2.10/-1.10/Sage!22,
        39.6/-1.30/1.80/Wheat!26,
        47.4/1.90/-1.50/Sage!30,
        54.8/-1.60/1.30/Wheat!34,
        61.8/1.70/-1.60/Sage!40,
        67.2/-1.10/1.40/Pine!32}{
      \fill[\cc]
        ($(current page.north west)+(0,-\yy cm)$)
        .. controls ($(current page.north west)+(30cm,-\yy cm+\aa cm)$)
               and ($(current page.north west)+(74cm,-\yy cm+\bb cm)$) ..
        ($(current page.north west)+(120cm,-\yy cm+0.3cm)$)
        -- (current page.south east) -- (current page.south west) -- cycle;
      \draw[AUgray!40,line width=1.2pt]
        ($(current page.north west)+(0,-\yy cm)$)
        .. controls ($(current page.north west)+(30cm,-\yy cm+\aa cm)$)
               and ($(current page.north west)+(74cm,-\yy cm+\bb cm)$) ..
        ($(current page.north west)+(120cm,-\yy cm+0.3cm)$);}
    % --- morning sun behind the header, left of the title ---
    % (halo first, then the core, then the inner ring)
    \draw[SunGold!45,line width=1.1pt]
      ($(current page.north west)+(12.9cm,-6.3cm)$) circle (6.8cm);
    \fill[SunGold!35]
      ($(current page.north west)+(12.9cm,-6.3cm)$) circle (5.0cm);
    \fill[SunGold]
      ($(current page.north west)+(12.9cm,-6.3cm)$) circle (4.3cm);
    \draw[SunGold!80,line width=1.6pt]
      ($(current page.north west)+(12.9cm,-6.3cm)$) circle (5.7cm);
    % --- three birds crossing the sky, left of the logo ---
    \foreach \bx/\by/\bs/\bo in {89.2/3.5/0.36/62, 92.8/4.7/0.29/52, 86.7/5.4/0.24/44}{
      \draw[Pine!\bo,line width=1.8pt,line cap=round]
        ($(current page.north west)+(\bx cm,-\by cm)$)
        .. controls +(0.5*\bs cm,0.55*\bs cm) .. +(\bs cm,0.05cm)
        ($(current page.north west)+(\bx cm+\bs cm,-\by cm+0.02cm)$)
        .. controls +(0.5*\bs cm,0.55*\bs cm) .. +(\bs cm,0.02cm);}
    % --- small life on the land: trees in the margins, bales in the gutters ---
    \foreach \tx/\ty/\ts in {1.30/56.4/1.00, 118.65/43.4/0.85}{
      \draw[Pine!60,line width=2.2pt,line cap=round]
        ($(current page.north west)+(\tx cm,-\ty cm)$) -- ++(0,0.55*\ts cm);
      \fill[Pine!48]
        ($(current page.north west)+(\tx cm,-\ty cm+0.55*\ts cm+0.45*\ts cm)$)
        circle (0.55*\ts cm);}
    \foreach \bx/\by in {38.5/53.0, 81.5/36.2}{
      \fill[Wheat!75] ($(current page.north west)+(\bx cm,-\by cm)$) circle (0.27cm);
      \draw[Wheat,line width=1.0pt]
        ($(current page.north west)+(\bx cm,-\by cm)$) circle (0.16cm);
      \draw[Wheat,line width=1.0pt]
        ($(current page.north west)+(\bx cm-0.27cm,-\by cm)$)
        arc[start angle=180,end angle=360,radius=0.27cm];}
    % --- the floating cards: shadow, fill, hairline ---
    \foreach \xa/\xb in {2.55/37.65, 39.35/80.65, 82.35/117.45}{
      \fill[Pine!13,rounded corners=0.55cm]
        ($(current page.north west)+(\xa cm+0.22cm,-11.85cm-0.26cm)$)
        rectangle
        ($(current page.north west)+(\xb cm+0.22cm,-61.75cm-0.26cm)$);
      \fill[CardWhite,rounded corners=0.55cm]
        ($(current page.north west)+(\xa cm,-11.85cm)$)
        rectangle
        ($(current page.north west)+(\xb cm,-61.75cm)$);
      \draw[Pine!22,line width=0.9pt,rounded corners=0.55cm]
        ($(current page.north west)+(\xa cm,-11.85cm)$)
        rectangle
        ($(current page.north west)+(\xb cm,-61.75cm)$);}
    \fill[Pine!13,rounded corners=0.55cm]
      ($(current page.north west)+(2.77cm,-63.56cm)$)
      rectangle ($(current page.north west)+(117.67cm,-68.81cm)$);
    \fill[CardWhite,rounded corners=0.55cm]
      ($(current page.north west)+(2.55cm,-63.30cm)$)
      rectangle ($(current page.north west)+(117.45cm,-68.55cm)$);
    \draw[Pine!22,line width=0.9pt,rounded corners=0.55cm]
      ($(current page.north west)+(2.55cm,-63.30cm)$)
      rectangle ($(current page.north west)+(117.45cm,-68.55cm)$);
  \end{tikzpicture}}

