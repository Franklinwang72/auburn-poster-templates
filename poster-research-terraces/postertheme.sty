% ======================================================================
%  Auburn University Research Poster -- accessible (PDF/UA-1 tagged)
%  THEME: Contour Fields -- agriculture as a modern, quiet landscape.
%  The whole page is a contour-farmed valley: sweeping terrace bands
%  that start as a near-white morning sky at the top and deepen, band
%  by band, toward the bottom edge, each ridge traced by a thin
%  contour line (level sets -- the geometer's landscape). The three
%  columns and the footer float above the fields on rounded white
%  cards with soft flat shadows; the gutters between the cards let the
%  terraces show through. A pale morning sun rises behind the title;
%  three birds cross the sky by the logo. No frames, no ornaments, no
%  small caps -- just the landscape, the cards, and the type.
%
%  Palette: warm near-white ground and cards, charcoal-green ink, deep
%  pine heads, ONE terracotta accent, sage and wheat for the fields.
%
%  Because this poster is a plain article (not beamer), it compiles to
%  a REAL tagged, PDF/UA-1 conformant PDF: reading order, language, and
%  the logo, figures, and QR code tagged as Figures with alt text.
%
%  COMPILE WITH LuaLaTeX:
%    * Overleaf:  Menu -> Compiler -> LuaLaTeX, then Recompile.
%    * Locally:   latexmk
% ======================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{postertheme}[2026/07/04 poster-research-terraces poster theme]


% Fail fast, with a clear message, if the wrong engine is used.
\RequirePackage{iftex}
\RequireLuaTeX

% ----- page: 120 x 72 cm landscape --------------------------------------
\RequirePackage[paperwidth=120cm, paperheight=72cm,
            top=2.4cm, bottom=2.0cm, left=3.4cm, right=3.4cm]{geometry}
\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.55em}
\setlength{\emergencystretch}{1.5em}  % kill loose justified lines

% ----- sans body (Source Sans 3) + Alegreya display + STIX math ---------
\RequirePackage{fontspec}
\setmainfont{SourceSans3}[Path=fonts/, Extension=.otf,
  UprightFont=*-Regular, BoldFont=*-Bold,
  ItalicFont=*-It,       BoldItalicFont=*-BoldIt]
\newfontfamily\PosterSemibold{SourceSans3}[Path=fonts/, Extension=.otf,
  UprightFont=*-Semibold, Ligatures=TeX]
\newfontfamily\PosterMedium{SourceSans3}[Path=fonts/, Extension=.otf,
  UprightFont=*-Medium, Ligatures=TeX]
\newfontfamily\DisplaySerif{Alegreya}[Path=fonts/, Extension=.otf,
  UprightFont=*-Medium, BoldFont=*-Bold, ItalicFont=*-Italic,
  Ligatures=TeX]
\RequirePackage{mathtools}
\RequirePackage{booktabs}
\RequirePackage{graphicx}
\RequirePackage{tikz}
\usetikzlibrary{calc}
\RequirePackage{unicode-math}
\setmathfont{STIXTwoMath-Regular.otf}[Path=fonts/]
\setoperatorfont\symup

% ----- colour: near-white ground, pine and terracotta on white cards -----
\RequirePackage{xcolor}
\definecolor{FieldPaper}{RGB}{250,248,240}  % the sky / page base
\definecolor{CardWhite}{RGB}{254,253,249}   % floating content cards
\definecolor{Pine}{RGB}{23,92,58}           % deep pine: heads, borders
\definecolor{Sage}{RGB}{152,172,136}        % field tint (green bands)
\definecolor{Wheat}{RGB}{224,198,142}       % field tint (gold bands)
\definecolor{SunGold}{RGB}{238,196,116}     % the morning sun
\definecolor{AUnavy}{RGB}{40,46,38}         % charcoal-green ink (text)
\definecolor{AUorange}{RGB}{178,80,43}      % ONE terracotta accent
\definecolor{AUgray}{RGB}{99,107,95}        % gray-green secondary
\pagecolor{FieldPaper}
\color{AUnavy}

% ----- tagged figures (hero, trio, torus, logo, QR), thesis pattern -----
\RequirePackage{qrcode}
\RequirePackage{zref-savepos}
\ExplSyntaxOn
\box_new:N \l__pfig_box
\int_new:N \g__pfig_int
\tl_new:N  \l__pfig_alt_tl
\cs_generate_variant:Nn \tag_struct_begin:n { e }
% \PosterFigure{<alt text>}{<content>} -- tag <content> as ONE Figure
% with alt text and a bounding box, exactly like an included image.
\NewDocumentCommand{\PosterFigure}{mm}{%
  \leavevmode
  \tl_set:Ne \l__pfig_alt_tl {#1}%
  \tag_struct_begin:e { tag=Figure , alt={\tl_to_str:N \l__pfig_alt_tl} }%
  \tag_mc_begin:n {}%
  \tag_suspend:n {pfig}%
  \hbox_set:Nn \l__pfig_box {#2}%
  \tag_resume:n {pfig}%
  \int_gincr:N \g__pfig_int
  \zsavepos { pfig \int_use:N \g__pfig_int }%
  \tag_struct_gput:ene { \tag_get:n {struct_num} } { attribute }
    { /O~/Layout~/BBox~[
        \dim_to_decimal_in_bp:n { \zposx{pfig\int_use:N\g__pfig_int} sp } ~
        \dim_to_decimal_in_bp:n { \zposy{pfig\int_use:N\g__pfig_int} sp
                                  - \box_dp:N \l__pfig_box } ~
        \dim_to_decimal_in_bp:n { \zposx{pfig\int_use:N\g__pfig_int} sp
                                  + \box_wd:N \l__pfig_box } ~
        \dim_to_decimal_in_bp:n { \zposy{pfig\int_use:N\g__pfig_int} sp
                                  + \box_ht:N \l__pfig_box } ] }%
  \box_use_drop:N \l__pfig_box
  \tag_mc_end:
  \tag_struct_end:
}
\ExplSyntaxOff

% ----- links -------------------------------------------------------------
\RequirePackage{hyperref}
\hypersetup{colorlinks=true, urlcolor=Pine, linkcolor=Pine,
