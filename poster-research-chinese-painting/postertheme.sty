    \draw[AUnavy!70,line width=2.4pt,line cap=round]
      (0.10,0.20) .. controls (0.85,0.72) and (1.48,0.48) .. (2.15,1.08)
      .. controls (2.88,0.42) and (3.38,0.58) .. (4.08,0.26);
    \draw[InkWash,line width=4.8pt,line cap=round]
      (0.58,0.02) .. controls (1.60,0.24) and (3.40,-0.05) .. (5.20,0.28);
    \fill[SealRed] (4.45,0.78) rectangle (5.20,1.53);
    \draw[RicePaper,line width=1.8pt] (4.58,0.92) -- (5.07,0.92);
    \draw[RicePaper,line width=1.8pt] (4.58,1.10) -- (5.07,1.10);
