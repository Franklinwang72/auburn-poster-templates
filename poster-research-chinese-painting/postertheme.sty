    \draw[RicePaper,line width=1.8pt] (4.94,0.88) -- (4.94,1.40);
  \end{tikzpicture}}
\newcommand{\StyleBackdrop}{%
  \begin{tikzpicture}[remember picture,overlay]
    \fill[PaleInk!55]
      ([xshift=0cm,yshift=-14.8cm]current page.north west)
      .. controls +(16cm,6cm) and +(-15cm,5cm) ..
      ([xshift=48cm,yshift=-14.2cm]current page.north west)
      .. controls +(12cm,-3cm) and +(-10cm,3cm) ..
      ([xshift=80cm,yshift=-15.0cm]current page.north west)
      .. controls +(12cm,-3cm) and +(-8cm,3cm) ..
      ([xshift=120cm,yshift=-13.8cm]current page.north west)
      -- ([xshift=120cm,yshift=-17.0cm]current page.north west)
      -- ([xshift=0cm,yshift=-17.0cm]current page.north west) -- cycle;
    \draw[AUnavy!20,line width=1.0pt]
      ([xshift=2.0cm,yshift=-2.0cm]current page.north west)
      rectangle
      ([xshift=-2.0cm,yshift=2.0cm]current page.south east);
    \foreach \y/\yy/\leafy in {-10/-15/-11.3,-18/-23/-19.3,-26/-31/-27.3,-34/-39/-35.3,-42/-47/-43.3,-50/-55/-51.3}{
      \draw[InkWash!34,line width=5.2pt,line cap=round]
        ($(current page.north west)+(2.0cm,\y cm)$)
        .. controls +(0.9cm,-2.4cm) and +(-0.6cm,2.2cm) ..
        ($(current page.north west)+(3.1cm,\yy cm)$);
      \fill[InkWash!28] ($(current page.north west)+(3.55cm,\leafy cm)$)
        ellipse (0.25cm and 0.78cm);
    }
    \fill[SealRed!16]
      ([xshift=-9.0cm,yshift=8.5cm]current page.south east) rectangle
      ([xshift=-4.8cm,yshift=12.7cm]current page.south east);
  \end{tikzpicture}}

