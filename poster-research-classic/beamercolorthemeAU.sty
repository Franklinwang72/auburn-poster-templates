% Gemini theme
% https://github.com/anishathalye/gemini

% ====================
% Definitions
% ====================

% Colors from https://ocm.auburn.edu/brand-center/_assets/pdf/au-colorpalette-primary-supporting.pdf

\definecolor{AUorange}{RGB}{232,97,0}
\definecolor{AUblue}{RGB}{11,35,65}
% Extra colors
\definecolor{AUlightblue}{RGB}{231,233,236} % Example block
\definecolor{AUlightorange}{RGB}{253,239,229} % Highlighted block

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=black,bg=white}
\setbeamercolor{palette secondary}{fg=black,bg=white}
\setbeamercolor{palette tertiary}{bg=black,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=AUblue}

% Headline
\setbeamercolor{headline}{fg=white,bg=AUblue}
% Orange accent bar under the headline and above the footer (Auburn brand)
\setbeamercolor{headline rule}{bg=AUorange}

% Block
\setbeamercolor{block title}{fg=AUblue,bg=white}
\setbeamercolor{block separator}{bg=AUorange}
\setbeamercolor{block body}{fg=black,bg=white}

% Alert Block
\setbeamercolor{block alerted title}{fg=AUblue,bg=AUlightorange}
\setbeamercolor{block alerted separator}{bg=AUblue}
\setbeamercolor{block alerted body}{fg=black,bg=AUlightorange}

% Example Block
\setbeamercolor{block example title}{fg=AUblue,bg=AUlightblue}
\setbeamercolor{block example separator}{bg=AUorange}
\setbeamercolor{block example body}{fg=black,bg=AUlightblue}

% Heading
\setbeamercolor{heading}{fg=black}

% Itemize
\setbeamercolor{item}{fg=AUblue}

% Bibliography
\setbeamercolor{bibliography item}{fg=black}
\setbeamercolor{bibliography entry author}{fg=black}
\setbeamercolor{bibliography entry title}{fg=black}
\setbeamercolor{bibliography entry location}{fg=black}
\setbeamercolor{bibliography entry note}{fg=black}
