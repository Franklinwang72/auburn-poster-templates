% Gemini theme
% https://github.com/anishathalye/gemini

% ====================
% Dependencies
% ====================

\RequirePackage{ragged2e}
\RequirePackage{changepage}
\RequirePackage{fontspec}
\RequirePackage{calc}

% ====================
% Fonts
% ====================

% Accessible, self-contained fonts (bundled in fonts/, matching the
% Auburn University LaTeX Template): Source Sans 3 for text and headings
% (the Graduate School's recommended accessible sans), Atkinson Hyperlegible
% Mono for code. Intermediate weights carry the heading hierarchy.
\newfontfamily\AUsemibold[Path=fonts/,Extension=.otf,UprightFont=*-Semibold,Ligatures=TeX]{SourceSans3}
\newfontfamily\AUmedium[Path=fonts/,Extension=.otf,UprightFont=*-Medium,Ligatures=TeX]{SourceSans3}

\usefonttheme{professionalfonts}

\setsansfont{SourceSans3}[Path=fonts/,Extension=.otf,
  UprightFont=*-Regular, BoldFont=*-Bold,
  ItalicFont=*-It,       BoldItalicFont=*-BoldIt]
\setmonofont{AtkinsonHyperlegibleMono}[Path=fonts/,Extension=.otf,
  UprightFont=*-Regular, BoldFont=*-Bold,
  ItalicFont=*-Italic,   BoldItalicFont=*-BoldItalic, Scale=MatchLowercase]

\newcommand{\PosterHeadlineTitleSize}{\fontsize{60}{68}\selectfont}
\newcommand{\PosterHeadlineAuthorSize}{\fontsize{24}{31}\selectfont}
\newcommand{\PosterHeadlineInstituteSize}{\fontsize{18.5}{25}\selectfont}
\newcommand{\PosterBlockTitleSize}{\fontsize{27.5}{34}\selectfont}
\newcommand{\PosterBlockBodySize}{\fontsize{22.5}{30.5}\selectfont}
\newcommand{\PosterCaptionSize}{\fontsize{16.2}{21.2}\selectfont}
\newcommand{\PosterFootlineSize}{\fontsize{17.5}{23}\selectfont}

\setbeamerfont{headline}{}
\setbeamerfont{headline title}{size=\PosterHeadlineTitleSize,series=\bfseries}
\setbeamerfont{headline author}{family=\AUmedium,size=\PosterHeadlineAuthorSize}
\setbeamerfont{headline institute}{family=\AUmedium,size=\PosterHeadlineInstituteSize}
\setbeamerfont{block title}{family=\AUsemibold,size=\PosterBlockTitleSize}
\setbeamerfont{block body}{size=\PosterBlockBodySize}
\setbeamerfont{heading}{family=\AUsemibold}
\setbeamerfont{caption}{family=\AUmedium,size=\PosterCaptionSize}
\setbeamerfont{footline}{size=\PosterFootlineSize}

% ====================
% Macros
% ====================


% ====================
% Elements
% ====================

% List
\def\@listi{\leftmargin\leftmarginii
\topsep 1ex % spacing before
\parsep 0\p@ \@plus\p@
\itemsep 0.5ex} % spacing between

% Itemize

\setbeamertemplate{itemize item}{\raise0.5ex \hbox{\vrule width 0.5ex height 0.5ex}}
\setbeamertemplate{itemize subitem}{\raise0.3ex \hbox{\vrule width 0.5ex height 0.5ex}}
\setbeamertemplate{itemize subsubitem}{\raise0.2ex \hbox{\vrule width 0.5ex height 0.5ex}}

% Enumerate

\setbeamertemplate{enumerate item}{\insertenumlabel.}
\setbeamertemplate{enumerate subitem}{\insertsubenumlabel.}
\setbeamertemplate{enumerate subsubitem}{\insertsubsubenumlabel.}

% Equation
\setlength\belowdisplayshortskip{2ex}

% Caption
\setbeamertemplate{caption}[numbered]
\setbeamertemplate{caption label separator}[period]
\setlength{\abovecaptionskip}{2ex}
\setlength{\belowcaptionskip}{1ex}

% Bibliography
\setbeamertemplate{bibliography item}[text]

% Navigation
\beamertemplatenavigationsymbolsempty

% ====================
% Components
% ====================

% Heading
\newcommand\heading[1]
{%
  \par\bigskip
  {\usebeamerfont{heading}\usebeamercolor[fg]{heading}#1}\par\smallskip
}

% logo
\newlength{\logoleftwidth}
\setlength{\logoleftwidth}{0cm}
\newlength{\logorightwidth}
\setlength{\logorightwidth}{0cm}
\newlength{\maxlogowidth}  % space on both sides set to maxlogowidth to keep title centered
\setlength{\maxlogowidth}{0cm}

\newcommand{\logoright}[1]{
  \gdef\insertlogoright{#1}
  \settowidth{\logorightwidth}{\insertlogoright}
  \addtolength{\logorightwidth}{10ex}
  \setlength{\maxlogowidth}{\maxof{\logoleftwidth}{\logorightwidth}}
}
\newcommand{\logoleft}[1]{
  \gdef\insertlogoleft{#1}
  \settowidth{\logoleftwidth}{\insertlogoleft}
  \addtolength{\logoleftwidth}{10ex}
  \setlength{\maxlogowidth}{\maxof{\logoleftwidth}{\logorightwidth}}
}

% Headline
\setbeamertemplate{headline}
{
  \begin{beamercolorbox}{headline}
    \begin{columns}
      \begin{column}{\maxlogowidth}
        \vskip5ex
        \ifdefined\insertlogoleft
        \vspace*{\fill}
        \hspace{10ex}
        \raggedright
        \insertlogoleft
        \vspace*{\fill}
        \else\fi
      \end{column}
      \begin{column}{\dimexpr\paperwidth-\maxlogowidth-\maxlogowidth}
        \usebeamerfont{headline}
        \vskip3ex
        \centering
        \ifx \inserttitle \empty \else
        {\usebeamerfont{headline title}\usebeamercolor[fg]{headline title}\inserttitle\\[1.5ex]}
        \fi
        \ifx \beamer@shortauthor \empty \else
        {\usebeamerfont{headline author}\usebeamercolor[fg]{headline author}\insertauthor\\[1ex]}
        \fi
        \ifx \insertinstitute \empty \else
        {\usebeamerfont{headline institute}\usebeamercolor[fg]{headline institute}\insertinstitute\\[1ex]}
        \fi
      \end{column}
      \begin{column}{\maxlogowidth}
        \vskip5ex
        \ifdefined\insertlogoright
        \vspace*{\fill}
        \raggedleft
        \insertlogoright
        \hspace{10ex}
        \vspace*{\fill}
        \else\fi
      \end{column}
    \end{columns}
    \vspace{5ex}
    \ifbeamercolorempty[bg]{headline rule}{}{
      \begin{beamercolorbox}[wd=\paperwidth,colsep=0.5ex]{headline rule}\end{beamercolorbox}
    }
  \end{beamercolorbox}
}

% Block
\setbeamertemplate{block begin}
{
  \begin{beamercolorbox}[colsep*=0ex,dp=2.1ex,center]{block title}
    \vskip0pt
    \usebeamerfont{block title}\insertblocktitle
    \vskip-0.85ex
    \begin{beamercolorbox}[colsep=0.04ex]{block separator}\end{beamercolorbox}
  \end{beamercolorbox}
  {\parskip0pt\par}
  \usebeamerfont{block body}
  \vskip0.45ex
  \begin{beamercolorbox}[colsep*=0ex]{block body}
  \RaggedRight % ragged right reads better at poster scale; use \justifying to justify
  \setlength{\parskip}{1.08ex}
  \setlength{\parindent}{0pt}
  \vskip0pt
}
\setbeamertemplate{block end}
{
  \end{beamercolorbox}
  \vskip0pt
  \vspace*{2.45ex}
}

% Alert Block
\setbeamertemplate{block alerted begin}
{
  \begin{beamercolorbox}[colsep*=0ex,dp=2.1ex,center]{block alerted title}
    \vskip0pt
    \usebeamerfont{block title}\insertblocktitle
    \vskip-0.85ex
    \begin{beamercolorbox}[colsep=0.04ex]{block alerted separator}\end{beamercolorbox}
  \end{beamercolorbox}
  {\parskip0pt\par}
  \usebeamerfont{block body}
  \vskip0.45ex
  \begin{beamercolorbox}[colsep*=0ex]{block alerted body}
  \RaggedRight % ragged right reads better at poster scale; use \justifying to justify
  \begin{adjustwidth}{1ex}{1ex}
  \setlength{\parskip}{1.08ex}
  \setlength{\parindent}{0pt}
  \vskip0pt
}
\setbeamertemplate{block alerted end}
{
  \end{adjustwidth}
  \vskip1ex
  \end{beamercolorbox}
  \vskip0pt
  \vspace*{2.45ex}
}

% Example Block
\setbeamertemplate{block example begin}
{
  \begin{beamercolorbox}[colsep*=0ex,dp=2.1ex,center]{block example title}
    \vskip0pt
    \usebeamerfont{block title}\insertblocktitle
    \vskip-0.85ex
    \begin{beamercolorbox}[colsep=0.04ex]{block example separator}\end{beamercolorbox}
  \end{beamercolorbox}
  {\parskip0pt\par}
  \usebeamerfont{block body}
  \vskip0.45ex
  \begin{beamercolorbox}[colsep*=0ex]{block example body}
  \RaggedRight % ragged right reads better at poster scale; use \justifying to justify
  \begin{adjustwidth}{1ex}{1ex}
  \setlength{\parskip}{1.08ex}
  \setlength{\parindent}{0pt}
  \vskip0pt
}
\setbeamertemplate{block example end}
{
  \end{adjustwidth}
  \vskip1ex
  \end{beamercolorbox}
  \vskip0pt
  \vspace*{2.45ex}
}

% Footer
\newcommand{\footercontent}[1]{\gdef\insertfootercontent{#1}}

\setbeamertemplate{footline}{
  \ifdefined\insertfootercontent
  \begin{beamercolorbox}[vmode]{headline}
    \ifbeamercolorempty[bg]{headline rule}{}{
      \begin{beamercolorbox}[wd=\paperwidth,colsep=0.25ex]{headline rule}\end{beamercolorbox}
    }
    \vspace{1.5ex}
    \hspace{\sepwidth}
    \usebeamerfont{footline}
    \centering
    \insertfootercontent
    \hspace{\sepwidth}
    \vspace{1.5ex}
  \end{beamercolorbox}
  \else\fi
}
