% ----- poster vocabulary -------------------------------------------------
% A wheat ear drawn inline: a short stem carrying three grain pairs and
% a tip grain. #1 = grain colour, #2 = stem colour, #3 = scale.
\newcommand{\WheatEar}[3]{%
  \tikz[baseline=-0.62ex,scale=#3]{%
    \draw[#2,line width=1.3pt,line cap=round] (0,-0.30) -- (0,0.26);
    \foreach \y/\s in {0.00/1.0, 0.14/0.88, 0.27/0.74}{
      \fill[#1,rotate around={36:(0.085,\y)}]
        (0.085,\y) ellipse ({0.15*\s} and {0.062*\s});
      \fill[#1,rotate around={-36:(-0.085,\y)}]
        (-0.085,\y) ellipse ({0.15*\s} and {0.062*\s});}
    \fill[#1] (0,0.40) ellipse (0.058 and 0.115);}}
% Quiet section label (loden, tracked caps) led by a wheat ear;
% [AUorange] (barn red) marks the ONE main-result label.
\NewDocumentCommand{\PosterSection}{O{AUnavy} m}{%
  \par\vspace{0.78em}%
  {\raggedright\PosterSemibold\fontsize{22.6}{27.0}\selectfont\color{#1}%
   \WheatEar{WheatGold}{OliveDeep}{0.95}%
   \hspace{0.30em}\addfontfeatures{LetterSpace=5}\MakeUppercase{#2}\par}%
  \vspace{0.10em}%
  {\color{LeafGreen!60}\rule{0.82\linewidth}{1.35pt}\par}%
  \vspace{-0.04em}}
% Run-in term label.
\newcommand{\auterm}[1]{{\PosterSemibold #1}}
\newcommand{\auhead}[1]{{\PosterSemibold #1}}
\newcommand{\PosterBody}{\fontsize{24.1}{33.0}\selectfont}
\newcommand{\PosterSmall}{\fontsize{19.2}{26.0}\selectfont}
\newcommand{\PosterCaption}{\fontsize{17.4}{23.2}\selectfont}
