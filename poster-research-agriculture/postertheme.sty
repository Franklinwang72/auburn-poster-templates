\RequirePackage[paperwidth=120cm, paperheight=72cm,
            top=2.4cm, bottom=2.0cm, left=3.4cm, right=3.4cm]{geometry}
\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.55em}
\setlength{\emergencystretch}{1.5em}  % kill loose justified lines

