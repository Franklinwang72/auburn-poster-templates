      -- (5.5,0.0) -- (0.0,0.0) -- cycle;
    % morning sun with rays
    \fill[WheatGold!90] (0.78,1.80) circle (0.33);
    \foreach \a in {0,45,...,315}{
      \draw[WheatGold!75,line width=1.6pt,line cap=round]
        ($(0.78,1.80)+(\a:0.46)$) -- ($(0.78,1.80)+(\a:0.66)$);}
    % barn: body, gambrel roof, door
    \fill[AUorange] (2.02,0.34) rectangle (3.10,1.06);
    \fill[AUorange!62!black]
      (1.90,1.06) -- (2.18,1.38) -- (2.56,1.50) -- (2.94,1.38)
      -- (3.22,1.06) -- cycle;
    \fill[GrainPaper] (2.40,0.34) rectangle (2.72,0.80);
    \draw[AUorange!70,line width=1.0pt]
      (2.40,0.34) -- (2.72,0.80) (2.40,0.80) -- (2.72,0.34);
    % silo with dome
    \fill[AUgray!85] (3.34,0.34) rectangle (3.78,1.30);
    \fill[AUgray!85] (3.56,1.30) circle (0.22);
    \draw[GrainPaper!80,line width=0.9pt]
      (3.34,0.62) -- (3.78,0.62) (3.34,0.92) -- (3.78,0.92);
    % wheat spray, leaning in the breeze
    \draw[OliveDeep,line width=1.5pt,line cap=round]
      (4.42,0.10) .. controls (4.46,0.60) .. (4.36,1.02);
    \draw[OliveDeep,line width=1.5pt,line cap=round]
      (4.78,0.08) .. controls (4.86,0.66) .. (4.96,1.14);
    \draw[OliveDeep,line width=1.5pt,line cap=round]
      (5.10,0.12) .. controls (5.22,0.52) .. (5.44,0.86);
    \foreach \x/\y/\r in {4.36/1.02/8, 4.96/1.14/-6, 5.44/0.86/-24}{
      \begin{scope}[shift={(\x,\y)},rotate=\r,scale=0.82]
        \foreach \yy/\s in {0.00/1.0, 0.13/0.86, 0.25/0.72}{
