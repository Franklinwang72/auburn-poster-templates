% Full-page backdrop: loden frame with a wheat-gold hairline, a faint
% morning sun in the top-left corner, birds by the logo, seedlings and
% grain dots down the side margins, and rolling fields along the bottom
% with contour-plough furrows, hay bales, and a windmill.
\newcommand{\StyleBackdrop}{%
  \begin{tikzpicture}[remember picture,overlay]
    % double frame: loden border + wheat-gold hairline
    \draw[AUnavy,line width=7pt]
      ([xshift=1.08cm,yshift=-1.08cm]current page.north west)
      rectangle
      ([xshift=-1.08cm,yshift=1.08cm]current page.south east);
    \draw[WheatGold!90,line width=1.6pt]
      ([xshift=1.62cm,yshift=-1.62cm]current page.north west)
      rectangle
      ([xshift=-1.62cm,yshift=1.62cm]current page.south east);
    % rolling fields along the bottom (back to front): a pale straw
    % hill on the left, a young-crop green rise on the right, and a
    % deep-olive ploughed field rolling across the front
    \fill[StrawLight!52]
      ($(current page.south west)+(0,1.6cm)$)
      .. controls +(14cm,2.9cm) and +(-16cm,0.6cm) ..
      ($(current page.south west)+(46cm,2.6cm)$)
      .. controls +(14cm,-1.6cm) and +(-12cm,0.1cm) ..
      ($(current page.south west)+(80cm,0.9cm)$)
      -- ($(current page.south west)+(80cm,0cm)$)
      -- (current page.south west) -- cycle;
    \fill[LeafGreen!38]
      ($(current page.south west)+(56cm,0.7cm)$)
      .. controls +(16cm,2.6cm) and +(-18cm,0.2cm) ..
      ($(current page.south west)+(106cm,2.4cm)$)
      .. controls +(6cm,0.9cm) and +(-6cm,-0.4cm) ..
      ($(current page.south east)+(0,3.1cm)$)
      -- ($(current page.south west)+(120cm,0cm)$)
      -- ($(current page.south west)+(56cm,0cm)$) -- cycle;
    \fill[OliveDeep!26]
      ($(current page.south west)+(0,0.7cm)$)
      .. controls +(22cm,2.0cm) and +(-24cm,0.7cm) ..
      ($(current page.south west)+(70cm,1.75cm)$)
      .. controls +(18cm,0.9cm) and +(-16cm,-0.5cm) ..
      ($(current page.south west)+(120cm,1.15cm)$)
      -- (current page.south east)
      -- (current page.south west) -- cycle;
    % contour-plough furrows following the front field
    \foreach \dy/\o in {0.34/46, 0.66/40, 0.98/33, 1.30/26}{
      \draw[OliveDeep!\o,line width=1.6pt]
        ($(current page.south west)+(0,0.7cm-0.45*\dy cm)$)
        .. controls +(22cm,2.0cm) and +(-24cm,0.7cm) ..
        ($(current page.south west)+(70cm,1.75cm-\dy cm)$)
        .. controls +(18cm,0.9cm) and +(-16cm,-0.5cm) ..
        ($(current page.south west)+(120cm,1.15cm-0.75*\dy cm)$);}
    % crop rows on the green rise
    \foreach \dy/\o in {0.55/42, 1.05/34, 1.55/26}{
      \draw[LeafGreen!\o,line width=1.4pt]
        ($(current page.south west)+(58cm,0.55cm)$)
        .. controls +(15cm,2.4cm-0.45*\dy cm) and +(-17cm,0.2cm) ..
        ($(current page.south west)+(106cm,2.4cm-\dy cm)$)
        .. controls +(6cm,0.8cm) and +(-6cm,-0.3cm) ..
        ($(current page.south east)+(0,3.1cm-1.1*\dy cm)$);}
    % hay bales resting on the straw hillside
    \foreach \x/\y/\r in {27/2.55/0.40, 33.5/2.30/0.32}{
      \fill[WheatGold!68]
        ($(current page.south west)+(\x cm,\y cm)$) circle (\r cm);
      \draw[WheatGold,line width=1.2pt]
        ($(current page.south west)+(\x cm,\y cm)$) circle ({0.58*\r cm});
      \draw[WheatGold,line width=1.2pt]
        ($(current page.south west)+(\x cm-\r cm,\y cm)$)
        arc[start angle=180,end angle=360,radius=\r cm];}
    % windmill on the green rise
    \draw[OliveDeep!62,line width=1.7pt,line cap=round]
      ($(current page.south west)+(93.4cm,1.7cm)$) --
      ($(current page.south west)+(94.3cm,3.85cm)$)
      ($(current page.south west)+(95.2cm,1.7cm)$) --
      ($(current page.south west)+(94.3cm,3.85cm)$);
    \draw[OliveDeep!50,line width=1.2pt]
      ($(current page.south west)+(93.75cm,2.55cm)$) --
      ($(current page.south west)+(94.85cm,2.55cm)$);
    \foreach \a in {35,125,215,305}{
      \draw[OliveDeep!62,line width=1.5pt,line cap=round]
        ($(current page.south west)+(94.3cm,3.85cm)$) --
        ($(current page.south west)+(94.3cm,3.85cm)+(\a:1.0cm)$);}
    \fill[OliveDeep!72] ($(current page.south west)+(94.3cm,3.85cm)$) circle (0.10cm);
    % birds in the sky, left of the logo
    \draw[AUnavy!32,line width=1.7pt,line cap=round]
      ($(current page.north west)+(98.0cm,-4.1cm)$)
      .. controls +(0.14cm,0.16cm) .. +(0.28cm,0.02cm)
      ($(current page.north west)+(98.28cm,-4.08cm)$)
      .. controls +(0.14cm,0.16cm) .. +(0.28cm,0.02cm);
    \draw[AUnavy!26,line width=1.5pt,line cap=round]
      ($(current page.north west)+(100.3cm,-3.1cm)$)
      .. controls +(0.12cm,0.14cm) .. +(0.24cm,0.02cm)
      ($(current page.north west)+(100.54cm,-3.08cm)$)
      .. controls +(0.12cm,0.14cm) .. +(0.24cm,0.02cm);
    \draw[AUnavy!22,line width=1.4pt,line cap=round]
      ($(current page.north west)+(95.7cm,-5.3cm)$)
      .. controls +(0.11cm,0.13cm) .. +(0.22cm,0.02cm)
      ($(current page.north west)+(95.92cm,-5.28cm)$)
      .. controls +(0.11cm,0.13cm) .. +(0.22cm,0.02cm);
    % seedlings and grain dots down the side margins. Each seedling is
    % drawn in a shifted LOCAL frame: "rotate around" cannot take a
    % calc ($...$) coordinate as its centre (the leaves swing across
    % the page), but a scope shift can.
    \foreach \side/\sgn in {west/1, east/-1}{
      \foreach \y in {12.5, 26.5, 40.5, 54.5}{
        \begin{scope}[shift={($(current page.north \side)+(\sgn*2.30cm,-\y cm)$)}]
          \draw[OliveDeep!48,line width=1.3pt,line cap=round]
            (0,-0.34) -- (0,0.02);
          \fill[LeafGreen!58,rotate around={34:(0,-0.08)}]
            (-0.17,-0.08) ellipse (0.17 and 0.062);
          \fill[LeafGreen!58,rotate around={-34:(0,-0.08)}]
            (0.17,-0.08) ellipse (0.17 and 0.062);
        \end{scope}}
      \foreach \y in {19.5, 33.5, 47.5, 60.5}{
        \fill[WheatGold!62]
          ($(current page.north \side)+(\sgn*2.30cm,-\y cm)$) circle (0.075cm);}}
  \end{tikzpicture}}

